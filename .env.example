# Server Configuration
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Database Configuration
# Local MongoDB:
MONGO_URI=mongodb://localhost:27017/meeting-intelligence

# MongoDB Atlas (Cloud):
# MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/meeting-intelligence?retryWrites=true&w=majority

# Google Gemini AI
# Get your API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# JWT Authentication
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_secret_key_here_minimum_32_characters_long
JWT_EXPIRY=7d

# Telegram Bot Configuration
# Get bot token from: https://t.me/botfather
# Get chat ID from: https://api.telegram.org/botYOUR_TOKEN/getUpdates
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Optional: Error Tracking Services
SENTRY_DSN=
BUGSNAG_API_KEY=

# Optional: Email Service
SENDGRID_API_KEY=
EMAIL_FROM=noreply@meeting-intelligence.com

# Optional: Redis Cache
REDIS_URL=redis://localhost:6379

# Optional: External APIs
SLACK_WEBHOOK_URL=
